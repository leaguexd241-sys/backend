{
  "name": "grassland-forest-relay",
  "version": "4.0.0",
  "description": "Server-Authoritative Relay System for Blockchain Games",
  "main": "server2.js",
  "scripts": {
    "start": "node server2.js",
    "dev": "nodemon server2.js",
    "dev-debug": "nodemon --inspect server2.js",
    "test": "jest --verbose",
    "test:relay": "jest relay.test.js --verbose",
    "lint": "eslint .",
    "format": "prettier --write '**/*.js'",
    "deploy:contracts": "hardhat run scripts/deploy.js --network somnia",
    "verify:contracts": "hardhat verify --network somnia",
    "seed:contracts": "node scripts/seed-contracts.js",
    "monitor:transactions": "node scripts/monitor-transactions.js",
    "backup:db": "node scripts/backup-database.js",
    "reset:limits": "node scripts/reset-player-limits.js",
    "health:check": "node scripts/health-check.js"
  },
  "keywords": [
    "blockchain",
    "relay",
    "server-authoritative",
    "game",
    "ethereum",
    "somnia",
    "phaser"
  ],
  "author": "Grassland Forest Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^6.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "ethers": "^6.8.0",
    "crypto": "^1.0.1",
    "uuid": "^9.0.0",
    "express-validator": "^7.0.1",
    "express-useragent": "^1.0.15",
    "request-ip": "^3.3.0",
    "geoip-lite": "^1.4.9",
    "web3": "^4.0.3",
    "socket.io": "^4.7.2",
    "compression": "^1.7.4",
    "axios": "^1.5.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "moment": "^2.29.4",
    "node-cron": "^3.0.2",
    "node-fetch": "^3.3.1",
    "prom-client": "^14.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "hardhat": "^2.17.0",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.8",
    "@nomicfoundation/hardhat-verify": "^1.0.4",
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "sinon": "^15.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grassland-forest/relay-system.git"
  },
  "bugs": {
    "url": "https://github.com/grassland-forest/relay-system/issues"
  },
  "homepage": "https://grasslandforest.com"
}
